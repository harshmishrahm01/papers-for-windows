#. Manually set name and icon
#: data/org.gnome.Papers.desktop.in.in:2
#: data/org.gnome.Papers.metainfo.xml.in.in:9
#: shell/resources/pps-document-view.blp:88
#: shell/resources/pps-loader-view.blp:10 shell/src/application.rs:47
#: shell/src/application.rs:389
msgid "Document Viewer"
msgstr "Przeglądarka dokumentów"

#: data/org.gnome.Papers.desktop.in.in:3
msgid "View multi-page documents"
msgstr "Wyświetlanie wielostronicowych dokumentów"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Papers.desktop.in.in:5
msgid "pdf;djvu;tiff;document;presentation;viewer;papers;"
msgstr "pdf;djvu;tiff;dokument;prezentacja;przeglądarka;evince;papers;"

#: data/org.gnome.Papers.desktop.in.in:20
msgid "New Window"
msgstr "Nowe okno"

#: data/org.gnome.Papers.gschema.xml:14
msgid "Override document restrictions"
msgstr "Bez uwzględniania ograniczeń dokumentu"

#: data/org.gnome.Papers.gschema.xml:15
msgid "Override document restrictions, like restriction to copy or to print."
msgstr ""
"Bez uwzględniania ograniczeń dokumentu, takich jak ograniczenie kopiowania "
"lub drukowania."

#: data/org.gnome.Papers.gschema.xml:19
msgid "The URI of the directory last used to open or save a document"
msgstr ""
"Adres URI katalogu ostatnio używanego do otwarcia lub zapisania dokumentu"

#: data/org.gnome.Papers.gschema.xml:23
msgid "The URI of the directory last used to save a picture"
msgstr "Adres URI katalogu ostatnio używanego do zapisania obrazu"

#: data/org.gnome.Papers.gschema.xml:27
msgid "Page cache size in MiB"
msgstr "Rozmiar bufora strony w MiB"

#: data/org.gnome.Papers.gschema.xml:28
msgid ""
"The maximum size that will be used to cache rendered pages, limits maximum "
"zoom level."
msgstr ""
"Maksymalny rozmiar, który będzie używany do buforowania wyświetlanych stron, "
"ogranicza maksymalny poziom powiększenia."

#: data/org.gnome.Papers.gschema.xml:32
msgid "Allow links to change the zoom level."
msgstr "Pozwala odnośnikom na zmianę powiększenia dokumentu."

#: data/org.gnome.Papers.gschema.xml:44
msgid "Check spelling when writing annotation notes or filling text forms."
msgstr ""
"Sprawdzanie pisowni podczas pisania przypisów lub wypełniania formularzy."

#: data/org.gnome.Papers.gschema.xml:48
msgid "Show a side bar next to the document to help navigate the document."
msgstr ""
"Wyświetlanie panelu bocznego obok dokumentu, aby pomóc się po nim poruszać."

#: data/org.gnome.Papers.gschema.xml:61
msgid "Set the default zoom level to display a document."
msgstr ""
"Ustawienie domyślnego poziomu powiększenia podczas wyświetlania dokumentu."

#: data/org.gnome.Papers.gschema.xml:65
msgid ""
"Display the document as a continuous stream of pages instead of page at a "
"time."
msgstr ""
"Wyświetlanie dokumentu jako ciągłego strumienia stron zamiast jednej strony "
"naraz."

#: data/org.gnome.Papers.gschema.xml:69
msgid "Show two pages side by side."
msgstr "Wyświetlanie dwóch stron obok siebie."

#: data/org.gnome.Papers.gschema.xml:73
msgid ""
"Show the first page (odd page) on the left (when displaying two pages side "
"by side)"
msgstr ""
"Wyświetlanie pierwszej (nieparzystej) strony po lewej (podczas wyświetlania "
"dwóch stron obok siebie)"

#: data/org.gnome.Papers.gschema.xml:110
msgid "Last used signature ID"
msgstr "Ostatnio użyty identyfikator podpisu"

#: data/org.gnome.Papers.gschema.xml:111
msgid "ID of the signature most recently used for manual signing"
msgstr "Ostatnio użyty identyfikator podpisu użyty do ręcznego podpisywania"

#: data/org.gnome.Papers.gschema.xml:118
msgid "Previewer window height"
msgstr "Wysokość okna podglądu"

#: data/org.gnome.Papers.gschema.xml:122
msgid "Previewer window width"
msgstr "Szerokość okna podglądu"

#: data/org.gnome.Papers.gschema.xml:126
msgid "Previewer window maximized state"
msgstr "Czy okno podglądu jest zmaksymalizowane"

#: data/org.gnome.Papers.metainfo.xml.in.in:10
msgid "Read documents"
msgstr "Czytaj dokumenty"

#: data/org.gnome.Papers.metainfo.xml.in.in:12
msgid ""
"A document viewer for the GNOME desktop. You can view, search or annotate "
"documents in many different formats."
msgstr ""
"Przeglądarka dokumentów dla środowiska GNOME. Umożliwia wyświetlanie, "
"przeszukiwanie i dodawanie przypisów do dokumentów w wielu różnych formatach."

#: data/org.gnome.Papers.metainfo.xml.in.in:13
msgid ""
"Papers supports documents in: PDF, DjVu, TIFF, and Comic Books archives "
"(CBR, CBT, CBZ, CB7)."
msgstr ""
"Dokumenty obsługuje dokumenty w formatach: PDF, DjVu, TIFF oraz archiwa "
"z komiksami (CBR, CBT, CBZ, CB7)."

#: data/org.gnome.Papers.metainfo.xml.in.in:65
msgid "A clear, simple, and modern UI"
msgstr "Prosty oraz przejrzysty interfejs"

#: data/org.gnome.Papers.metainfo.xml.in.in:69
msgid "A mobile-friendly UI"
msgstr "Interfejs dostosowany do urządzeń mobilnych"

#: data/org.gnome.Papers.metainfo.xml.in.in:73
msgid "A modern and colorful annotation list"
msgstr "Nowoczesna i kolorowa lista przypisów"

#: data/org.gnome.Papers.metainfo.xml.in.in:77
msgid "Big thumbnails in the sidebar"
msgstr "Duże miniatury na pasku bocznym"

#: data/org.gnome.Papers.metainfo.xml.in.in:81
msgid "All search actions are contained in the sidebar"
msgstr "Wszystkie działania wyszukiwania są zawarte na pasku bocznym"

#: data/org.gnome.Papers-previewer.desktop.in.in:2
msgid "Print Preview"
msgstr "Podgląd wydruku"

#: data/org.gnome.Papers-previewer.desktop.in.in:3
msgid "Preview before printing"
msgstr "Podgląd przed drukowaniem"

#: libdocument/backend/comics/comics-document.c:179
#: libdocument/backend/comics/comics-document.c:248
